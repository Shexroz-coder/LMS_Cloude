# ─── Backend Environment Variables ───────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Database (local development)
DATABASE_URL=postgresql://lms_user:password@localhost:5432/lms_robotic

# Redis (local development)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev_jwt_secret_change_in_production_min32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_min32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# PayMe
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_merchant_key
