# ══════════════════════════════════════════════════════════
# Robotic Edu LMS — Environment Variables
# Bu faylni .env nomiga nusxalang va qiymatlarni o'zgartiring
# ══════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────
POSTGRES_DB=lms_robotic
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change_this_strong_password

DATABASE_URL=postgresql://lms_user:change_this_strong_password@postgres:5432/lms_robotic
DATABASE_URL="postgresql://postgres:password@localhost:5432/lms_db"
JWT_SECRET="1234"
# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@redis:6379

# ─── JWT Secrets (MUHIM: Xavfsiz, uzun stringlar kiriting!) ──
JWT_SECRET=minimum_32_chars_random_secret_here_changeme
JWT_REFRESH_SECRET=another_minimum_32_chars_secret_here_changeme
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── App Settings ─────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost

# ─── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=/api/v1
