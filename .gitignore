# Dependencies
node_modules/
**/node_modules/

# Environment files
.env
**/.env
!.env.example
!**/.env.example

# Build outputs
dist/
build/
**/dist/
**/build/

# Logs
*.log
logs/
**/logs/

# Uploads (don't commit user files)
uploads/
**/uploads/
!uploads/.gitkeep

# Database
*.db
*.sqlite

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp

# Prisma generated
backend/src/generated/

# Docker volumes (these are runtime data)
postgres_data/
redis_data/

# SSL certs (keep example, not real certs)
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key
!nginx/ssl/.gitkeep
